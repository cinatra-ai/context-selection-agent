      "name": "Branch on selection mode",
      "metadata": {
        "cinatra": {
          "purpose": "route-autonomous-slots-around-the-HITL-gate"
        }
      },
      "inputs": [
        {
          "title": "selectionMode",
          "type": "string"
        }
      ],
      "outputs": [],
      "branches": [
        "default",
        "autonomous"
      ],
      "mapping": {
        "autonomous": "autonomous"
      }
    },
    "emit_context_payload": {
      "component_type": "OutputMessageNode",
      "id": "emit_context_payload",
      "name": "Emit resolved context as agent message",
      "inputs": [
        {
          "title": "candidates",
          "type": "array",
          "json_schema": {
            "items": {
              "type": "object"
            }
          }
        },
        {
          "title": "slotMeta",
          "type": "object"
        },
        {
          "title": "selectedRefs",
          "type": "array",
          "json_schema": {
            "items": {
              "type": "object"
            }
          }
        }
      ],
      "message": "{# pyagentspec-input-hint (do not remove): {{ candidates }} {{ slotMeta }} {{ selectedRefs }} #}{\"candidates\":{{ candidates | tojson }},\"slotMeta\":{{ slotMeta | tojson }},\"selectedRefs\":{{ selectedRefs | tojson }}}"
    },
    "context_select_gate": {
      "component_type": "InputMessageNode",
      "id": "context_select_gate",
      "name": "Select context",
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": true,
          "renderer": "@cinatra-ai/context-selection-agent:context-selector",
          "a2uiSurfaceId": "context-selection:select"
