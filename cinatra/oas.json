          "title": "slotMeta",
          "type": "object"
        },
        {
          "title": "selectedRefs",
          "type": "array",
          "json_schema": {
            "items": {
              "type": "object"
            }
          }
        },
        {
          "title": "selectionMode",
          "type": "string"
        },
        {
          "title": "resolutionMode",
          "type": "string"
        }
      ]
