        "slotId": "{{ slotId }}",
        "projectId": "{{ projectId }}",
        "selectionMode": "{{ selectionMode }}",
        "userResponse": "{{ userResponse }}"
      },
      "inputs": [
        {
          "title": "parentRunId",
          "type": "string"
        },
        {
          "title": "parentPackageName",
          "type": "string"
        },
        {
          "title": "slotId",
          "type": "string"
        },
        {
          "title": "projectId",
          "type": "string",
          "default": ""
        },
        {
          "title": "selectionMode",
          "type": "string"
        },
        {
          "title": "userResponse",
          "type": "string"
        }
      ],
      "outputs": [
