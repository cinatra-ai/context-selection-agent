          "title": "parentRunId",
          "type": "string"
        },
        {
          "title": "parentPackageName",
          "type": "string"
        },
        {
          "title": "slotId",
          "type": "string"
        },
        {
          "title": "projectId",
          "type": "string",
          "default": ""
        },
        {
          "title": "selectionMode",
          "type": "string"
        },
        {
          "title": "resolutionMode",
          "type": "string"
        },
        {
          "title": "selectedRefs",
          "type": "array",
          "json_schema": {
            "items": {
              "type": "object"
            }
          }
        }
      ],
      "outputs": [
