      "component_type": "DataFlowEdge",
      "name": "finalize_autonomous_to_end",
      "source_node": {
        "$component_ref": "finalize_autonomous"
      },
      "source_output": "contextSlotBindings",
      "destination_node": {
        "$component_ref": "end"
      },
      "destination_input": "contextSlotBindings"
    }
  ],
  "$referenced_components": {
    "start": {
      "component_type": "StartNode",
      "id": "start",
      "name": "Inputs",
      "metadata": {
        "cinatra": {
          "required": [
            "parentRunId",
            "parentPackageName",
            "slotId"
          ],
          "hidden": [
            "parentRunId",
            "parentPackageName",
            "slotId",
            "projectId"
          ]
        }
      },
      "inputs": [
        {
          "title": "parentRunId",
          "type": "string"
        },
        {
          "title": "parentPackageName",
          "type": "string"
        },
        {
          "title": "slotId",
          "type": "string"
        },
        {
          "title": "projectId",
          "type": "string",
          "default": ""
        }
      ]
    },
    "resolve_context": {
      "component_type": "ApiNode",
      "id": "resolve_context",
      "name": "Resolve context candidates",
      "url": "{{CINATRA_BASE_URL}}/api/context-resolve",
      "http_method": "POST",
      "data": {
        "parentRunId": "{{ parentRunId }}",
        "parentPackageName": "{{ parentPackageName }}",
        "slotId": "{{ slotId }}",
        "projectId": "{{ projectId }}"
      },
      "inputs": [
        {
          "title": "parentRunId",
          "type": "string"
        },
        {
          "title": "parentPackageName",
          "type": "string"
        },
        {
          "title": "slotId",
          "type": "string"
        },
        {
          "title": "projectId",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "candidates",
          "type": "array",
          "json_schema": {
            "items": {
              "type": "object"
