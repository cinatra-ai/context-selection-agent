{
  "agentspec_version": "26.1.0",
  "component_type": "Flow",
  "id": "context-agent-flow",
  "name": "Context Agent",
  "description": "Non-uninstallable core context-resolver sub-agent. Invoked explicitly: a context-using agent declares @cinatra-ai/context-selection-agent in its agentDependencies and includes an explicit context FlowNode per slot before the slot-consuming node (child-local invocation, not runtime auto-wiring). Resolves a slot to a set of pinned artifact refs (artifactId + representationRevisionId + semanticAssertionId) via /api/context-resolve, opens the ContextSelector HITL when selectionMode=interactive (autonomous slots skip the gate via the branch), writes the run_context_selections audit rows via /api/context-finalize, and emits output_data.contextSlotBindings for the calling agent to consume via {{context_<slotId>.contextSlotBindings}}.",
  "metadata": {
    "cinatra": {
      "type": "flow",
      "packageName": "@cinatra-ai/context-selection-agent",
      "packageVersion": "0.3.0",
      "hitlScreens": [
        "@cinatra-ai/context-selection-agent:context-selector"
      ],
      "produces": [],
      "agentDependencies": [],
      "contextSlots": []
    }
  },
  "inputs": [
    {
      "title": "parentRunId",
      "type": "string"
    },
    {
      "title": "parentPackageName",
      "type": "string"
    },
    {
      "title": "slotId",
      "type": "string"
    },
    {
      "title": "projectId",
      "type": "string",
      "default": ""
    }
  ],
  "outputs": [
    {
      "title": "contextSlotBindings",
      "type": "array",
      "json_schema": {
        "items": {
          "type": "object"
        }
      }
    }
  ],
  "start_node": {
    "$component_ref": "start"
  },
  "nodes": [
    {
      "$component_ref": "start"
    },
    {
      "$component_ref": "resolve_context"
    },
    {
      "$component_ref": "select_mode"
    },
    {
      "$component_ref": "emit_context_payload"
    },
    {
      "$component_ref": "context_select_gate"
    },
    {
      "$component_ref": "finalize_interactive"
    },
    {
      "$component_ref": "finalize_autonomous"
    },
    {
      "$component_ref": "end"
    }
  ],
  "control_flow_connections": [
    {
      "component_type": "ControlFlowEdge",
      "name": "start_to_resolve",
      "from_node": {
        "$component_ref": "start"
      },
      "to_node": {
        "$component_ref": "resolve_context"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "resolve_to_select",
      "from_node": {
        "$component_ref": "resolve_context"
      },
      "to_node": {
        "$component_ref": "select_mode"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "select_default_to_emit",
      "from_node": {
        "$component_ref": "select_mode"
      },
      "to_node": {
        "$component_ref": "emit_context_payload"
      },
      "from_branch": "default"
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "emit_to_gate",
      "from_node": {
        "$component_ref": "emit_context_payload"
      },
      "to_node": {
        "$component_ref": "context_select_gate"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "gate_to_finalize_interactive",
      "from_node": {
        "$component_ref": "context_select_gate"
      },
      "to_node": {
        "$component_ref": "finalize_interactive"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "finalize_interactive_to_end",
      "from_node": {
        "$component_ref": "finalize_interactive"
      },
      "to_node": {
        "$component_ref": "end"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "select_autonomous_to_finalize",
      "from_node": {
        "$component_ref": "select_mode"
      },
      "to_node": {
        "$component_ref": "finalize_autonomous"
      },
      "from_branch": "autonomous"
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "finalize_autonomous_to_end",
      "from_node": {
        "$component_ref": "finalize_autonomous"
      },
      "to_node": {
        "$component_ref": "end"
      }
    }
  ],
  "data_flow_connections": [
    {
      "component_type": "DataFlowEdge",
      "name": "start_parentRunId_to_resolve",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentRunId",
      "destination_node": {
        "$component_ref": "resolve_context"
      },
      "destination_input": "parentRunId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_parentPackageName_to_resolve",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentPackageName",
      "destination_node": {
        "$component_ref": "resolve_context"
      },
      "destination_input": "parentPackageName"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_slotId_to_resolve",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "slotId",
      "destination_node": {
        "$component_ref": "resolve_context"
      },
      "destination_input": "slotId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_projectId_to_resolve",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "projectId",
      "destination_node": {
        "$component_ref": "resolve_context"
      },
      "destination_input": "projectId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "resolve_selectionMode_to_select",
      "source_node": {
        "$component_ref": "resolve_context"
      },
      "source_output": "selectionMode",
      "destination_node": {
        "$component_ref": "select_mode"
      },
      "destination_input": "selectionMode"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "resolve_candidates_to_emit",
      "source_node": {
        "$component_ref": "resolve_context"
      },
      "source_output": "candidates",
      "destination_node": {
        "$component_ref": "emit_context_payload"
      },
      "destination_input": "candidates"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "resolve_slotMeta_to_emit",
      "source_node": {
        "$component_ref": "resolve_context"
      },
      "source_output": "slotMeta",
      "destination_node": {
        "$component_ref": "emit_context_payload"
      },
      "destination_input": "slotMeta"
