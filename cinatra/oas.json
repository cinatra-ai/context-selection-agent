      "http_method": "POST",
      "data": {
        "parentRunId": "{{ parentRunId }}",
        "parentPackageName": "{{ parentPackageName }}",
        "slotId": "{{ slotId }}",
        "projectId": "{{ projectId }}",
        "selectionMode": "{{ selectionMode }}",
        "userResponse": "{# pyagentspec-input-hint (do not remove): {{ slotId }} {{ resolutionMode }} {{ selectedRefs }} #}{\"slotId\":{{ slotId | tojson }},\"resolutionMode\":{{ resolutionMode | tojson }},\"selectedRefs\":{{ selectedRefs | tojson }}}"
      },
      "inputs": [
