      },
      "source_output": "userResponse",
      "destination_node": {
        "$component_ref": "finalize_interactive"
      },
      "destination_input": "userResponse"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_parentRunId_to_finalize_interactive",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentRunId",
      "destination_node": {
        "$component_ref": "finalize_interactive"
      },
      "destination_input": "parentRunId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_parentPackageName_to_finalize_interactive",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentPackageName",
      "destination_node": {
        "$component_ref": "finalize_interactive"
      },
      "destination_input": "parentPackageName"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_slotId_to_finalize_interactive",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "slotId",
      "destination_node": {
        "$component_ref": "finalize_interactive"
      },
      "destination_input": "slotId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_projectId_to_finalize_interactive",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "projectId",
      "destination_node": {
        "$component_ref": "finalize_interactive"
      },
      "destination_input": "projectId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "resolve_selectionMode_to_finalize_interactive",
      "source_node": {
        "$component_ref": "resolve_context"
      },
      "source_output": "selectionMode",
      "destination_node": {
        "$component_ref": "finalize_interactive"
      },
      "destination_input": "selectionMode"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_parentRunId_to_finalize_autonomous",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentRunId",
      "destination_node": {
        "$component_ref": "finalize_autonomous"
      },
      "destination_input": "parentRunId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_parentPackageName_to_finalize_autonomous",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentPackageName",
